VITE_API_URL=http://localhost:8000

# OpenWeatherMap API Key (https://openweathermap.org/api)
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Real-time mode (mqtt or api)
VITE_REALTIME_MODE=mqtt
# Polling interval in milliseconds (used when mode=api)
VITE_REALTIME_POLL_INTERVAL_MS=5000

# MQTT Configuration
VITE_MQTT_BROKER=your_mqtt_broker_host
VITE_MQTT_PORT=8884
VITE_MQTT_USERNAME=your_mqtt_username
VITE_MQTT_PASSWORD=your_mqtt_password
